@model IReadOnlyList<TicketDto>
@{
    ViewData["Title"] = "Biletlerim";
}

<h1 class="mb-4">Biletlerim</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Henüz bilet satın almadınız.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tarih</th>
                    <th>Etkinlik</th>
                    <th>Koltuk</th>
                    <th>Tutar</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td class="text-nowrap small">@t.PurchaseDate.ToLocalTime().ToString("dd/MM/yyyy HH.mm")</td>
                    <td>@t.EventTitle</td>
                    <td>@t.SeatNumber</td>
                    <td>@t.Price.ToString("C")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary me-1" asp-action="DownloadPdf" asp-route-id="@t.Id">PDF İndir</a>
                        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#qrModal-@t.Id">QR Göster</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @foreach (var t in Model)
    {
        <div class="modal fade" id="qrModal-@t.Id" tabindex="-1" aria-labelledby="qrModalLabel-@t.Id" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="qrModalLabel-@t.Id">QR Kod - @t.EventTitle / @t.SeatNumber</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center">
                        <img src="@Url.Action("GenerateQrCode", "Ticket", new { id = t.Id })" alt="QR Kod" class="img-fluid" />
                        <p class="mt-2 small text-muted">Bilet ID: @t.Id</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                        <a href="@Url.Action("GenerateQrCode", "Ticket", new { id = t.Id })" class="btn btn-primary" download="@($"qr-{t.Id:N}.png")">İndir</a>
                    </div>
                </div>
            </div>
        </div>
    }
}