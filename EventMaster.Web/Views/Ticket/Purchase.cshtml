@model PurchaseTicketRequest
@{
    ViewData["Title"] = "Bilet satın al";
    var evs = (IReadOnlyList<EventDto>)ViewBag.ApprovedEvents!;
}

<h1 class="mb-4">Bilet satın al</h1>

@if (evs.Count == 0)
{
    <div class="alert alert-warning">Onaylı etkinlik yok. Önce bir etkinliğin onaylanması gerekir.</div>
}
else
{
    <form asp-action="Checkout" method="post" class="col-lg-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label class="form-label">Etkinlik</label>
            <select class="form-select" asp-for="EventId">
                @foreach (var e in evs)
                {
                    <option value="@e.Id">@e.Title — @e.StartTime.ToLocalTime().ToString("dd/MM/yyyy HH.mm")</option>
                }
            </select>
        </div>
        <div id="seatHiddenInputs"></div>
        <div class="mb-2">
            <div class="d-flex align-items-center justify-content-between">
                <label class="form-label mb-0">Koltuk seç</label>
                <div class="small text-muted">Seçili: <span id="selectedSeatLabel">—</span></div>
            </div>
        </div>
        <div class="seat-legend mb-2 small">
            <span class="seat-legend-item"><span class="seat seat--available"></span> Müsait</span>
            <span class="seat-legend-item"><span class="seat seat--held"></span> Tuttuğun</span>
            <span class="seat-legend-item"><span class="seat seat--sold"></span> Dolu</span>
            <span class="seat-legend-item"><span class="seat seat--blocked"></span> Başkası tutmuş</span>
        </div>
        <div id="seatPicker" class="seat-picker mb-3" data-seat-picker="1"></div>
        <div class="mb-3">
            <label class="form-label">Toplam fiyat (demo)</label>
            <input id="totalPrice" class="form-control" value="0" readonly />
        </div>
        <button type="submit" class="btn btn-primary">Satın al</button>
    </form>

    @section Scripts
    {
        <script src="~/js/seat-picker.js" asp-append-version="true"></script>
    }
}
