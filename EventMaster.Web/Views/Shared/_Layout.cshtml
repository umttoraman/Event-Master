<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Event Master</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">Event Master</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Panel</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Event" asp-action="Index">Etkinlikler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Room" asp-action="Index">Odalar</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Ticket" asp-action="Purchase">Bilet Al</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Ticket" asp-action="MyTickets">Biletlerim</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="RoomSeat" asp-action="Index">Koltuk Düzeni</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Ticket" asp-action="Report">Finans Raporu</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="AuditLogs">Denetim Kayıtları</a></li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><span class="navbar-text text-white me-3 small">@User.Identity.Name (@User.FindFirst(ClaimTypes.Role)?.Value)</span></li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-sm">Çıkış</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Login">Giriş</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Register">Kayıt</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container py-4">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">@TempData["Message"]</div>
        }
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top py-3 mt-auto bg-white small text-muted">
        <div class="container">
            &copy; @DateTime.UtcNow.Year Event Master — örnek kurumsal ödev
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
