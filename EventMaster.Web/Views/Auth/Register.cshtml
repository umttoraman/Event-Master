@model RegisterRequest
@{
    ViewData["Title"] = "Kayıt";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Kayıt (Müşteri)</h2>
        <p class="small text-muted">Kayıt olan kullanıcılar varsayılan olarak <strong>Customer</strong> rolü ile oluşturulur.</p>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label class="form-label" asp-for="Username"></label>
                <input class="form-control" asp-for="Username" autocomplete="username" />
            </div>
            <div class="mb-3">
                <label class="form-label" asp-for="Password"></label>
                <input class="form-control" asp-for="Password" type="password" autocomplete="new-password" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Kayıt ol</button>
        </form>
        <p class="mt-3 small"><a asp-action="Login">Zaten hesabınız var mı? Giriş</a></p>
    </div>
</div>
