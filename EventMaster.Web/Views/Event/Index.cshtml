@model IReadOnlyList<EventDto>
@{
    ViewData["Title"] = "Etkinlikler";
    var isAdmin = User.IsInRole("Admin");
    var isOrg = User.IsInRole("Organizer") || isAdmin;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="mb-0">Etkinlikler</h1>
    @if (isOrg)
    {
        <a class="btn btn-primary" asp-action="Create">Yeni etkinlik</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle small">
        <thead class="table-light">
            <tr>
                <th>Başlık</th>
                <th>Başlangıç</th>
                <th>Bitiş</th>
                <th>Durum</th>
                <th>Oda</th>
                <th>Organizatör</th>
                <th>Bilet</th>
                <th style="min-width:220px">İşlemler</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td><a asp-action="Details" asp-route-id="@e.Id">@e.Title</a></td>
                <td class="text-nowrap">@e.StartTime.ToLocalTime().ToString("dd/MM/yyyy HH.mm")</td>
                <td class="text-nowrap">@e.EndTime.ToLocalTime().ToString("dd/MM/yyyy HH.mm")</td>
                <td><span class="badge bg-info text-dark">@e.Status</span></td>
                <td>@e.RoomName</td>
                <td>@e.OrganizerName</td>
                <td>@e.TicketsSold</td>
                <td>
                    <div class="d-flex flex-column gap-1">
                        @if (isOrg && e.Status == EventStatus.Draft)
                        {
                            <form asp-action="SubmitForApproval" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary w-100">Onaya gönder</button>
                            </form>
                        }
                        @if (isAdmin && e.Status == EventStatus.Pending)
                        {
                            <form asp-action="Approve" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id" />
                                <button type="submit" class="btn btn-sm btn-success w-100">Onayla</button>
                            </form>
                            <form asp-action="Reject" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Reddet (taslak)</button>
                            </form>
                        }
                        @if (isOrg && e.Status == EventStatus.Draft)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@e.Id">Düzenle</a>
                            <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Silinsin mi?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
